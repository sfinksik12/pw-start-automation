{
  "name": "pw-start-automation",
  "version": "1.0.0",
  "description": "Playwright start automation",
  "type": "module",
  "main": "./index.ts",
  "module": "./index.ts",
  "types": "./index.ts",
  "files": [
    "src",
    "index.ts"
  ],
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "gapix": "gapix analyze . -o html",
    "gapix:no-ai": "GAPIX_USE_AI=false gapix analyze . -o html",
    "gapix:src": "gapix analyze . -p \"src/**/*.ts\" -p \"tests/**/*.spec.ts\" -o html",
    "gapix:tests": "gapix analyze . -p \"src/ui/**/*.ts\" -p \"tests/**/*.spec.ts\" -o html"
  },
  "author": "Pavel Schelokov",
  "license": "ISC",
  "keywords": [],
  "resolutions": {},
  "overrides": {
    "chalk": "^4.1.2",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@artshllaku/gapix": "^1.1.2",
    "@faker-js/faker": "^9.7.0",
    "@playwright/test": "1.58.0",
    "@types/node": "^24.0.1",
    "allure-commandline": "^2.30.0",
    "allure-playwright": "^2.15.1",
    "typescript": "^5.9.3"
  }
}
