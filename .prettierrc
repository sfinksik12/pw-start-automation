{
  // Prettier — автоматическое форматирование кода
  // Команды: npm run format (запись), npm run format:check (проверка)

  "semi": true,
  "trailingComma": "all",
  "singleQuote": true,
  "printWidth": 300,
  "tabWidth": 2,
  "useTabs": false,
  "bracketSpacing": true,
  "arrowParens": "avoid",
  "proseWrap": "preserve",
  "endOfLine": "lf"
}
